{
    "name": "pathway/wp-route-manager",
    "description": "Custom REST API endpoint, webhook ingestion, PHP snippet runner and action dispatcher for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Pathway Group",
            "homepage": "https://pathwayskillszone.ac.uk"
        }
    ],
    "require": {
        "php": ">=8.1",
        "wp-cli/wp-cli-bundle": "^2.12"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "WP_Route_Manager\\": "src/"
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=WordPress src/ --extensions=php",
        "phpcbf": "phpcbf --standard=WordPress src/ --extensions=php",
        "phpstan": "phpstan analyse src/ --level=6 --configuration=phpstan.neon"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "wordpress-install-dir": "wordpress"
    }
}
